/* == Modern Professional Student Dashboard == */
* { box-sizing: border-box; }

:root {
  /* FEU Brand Colors */
  --feu-green: #0A5C2E;
  --feu-green-light: #15723A;
  --feu-green-lighter: #1A8C44;
  --feu-gold: #D4A017;
  --feu-gold-light: #E8B82D;
  --feu-gold-lighter: #F0D05A;

  /* UI Colors */
  --sidebar-bg: #0A5C2E;
  --sidebar-bg-hover: #15723A;
  --sidebar-text: #ffffff;
  --sidebar-text-muted: #d1e8d8;
  --sidebar-divider: rgba(255, 255, 255, 0.12);
  --accent-primary: #0A5C2E;
  --accent-primary-hover: #15723A;
  --accent-gold: #D4A017;
  --accent-gold-hover: #E8B82D;
  --bg-primary: #f8fafc;
  --bg-card: #ffffff;
  --bg-hover: #f1f5f9;
  --text-primary: #1e293b;
  --text-secondary: #64748b;
  --text-muted: #94a3b8;
  --border-light: #e2e8f0;
  --border-medium: #cbd5e1;
  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 8px 24px rgba(10, 92, 46, 0.14);
  --radius-sm: 6px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
}

body {
  margin: 0;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: var(--bg-primary);
  color: var(--text-primary);
  display: flex;
  min-height: 100vh;
}

/* == Layout == */
.content-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  transition: margin-left 0.3s ease;
}

/* == Sidebar == */
.main-sidebar {
  width: 260px;
  min-height: 100vh;
  background: var(--sidebar-bg);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  position: fixed;
  left: 0;
  top: 0;
  z-index: 1000;
  transform: translateX(0);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  box-shadow: var(--shadow-lg);
}

.main-sidebar.collapsed {
  transform: translateX(-100%);
  box-shadow: none;
}

.content-wrapper.sidebar-collapsed {
  margin-left: 0;
}

.content-wrapper:not(.sidebar-collapsed) {
  margin-left: 260px;
}

@media (max-width: 600px) {
  .content-wrapper:not(.sidebar-collapsed) {
    margin-left: 0;
  }
}

.brand-link {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-decoration: none;
  padding: 24px 20px 16px;
}

.brand-logo {
  width: 80px;
  height: 80px;
  border-radius: 16px;
  background: var(--feu-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
  overflow: hidden;
  box-shadow: 0 4px 16px rgba(212, 160, 23, 0.3);
}

.brand-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 14px;
}

.brand-title {
  color: var(--sidebar-text);
  font-size: 22px;
  font-weight: 700;
  letter-spacing: 0.5px;
  margin: 0;
  text-align: center;
}

.brand-subtitle {
  color: var(--sidebar-text-muted);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.5px;
  text-align: center;
  margin-top: 4px;
  line-height: 1.5;
}

.sidebar-divider {
  border: none;
  border-top: 1px solid var(--sidebar-divider);
  margin: 4px 0 16px;
}

.sidebar {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 20px;
}

.nav-sidebar {
  list-style: none;
  margin: 0;
  padding: 8px 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  color: var(--sidebar-text);
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  border-radius: 10px;
  transition: all 0.2s ease;
}

.nav-link i {
  width: 20px;
  text-align: center;
  font-size: 15px;
  color: var(--sidebar-text-muted);
  flex-shrink: 0;
  transition: color 0.2s ease;
}

.nav-link:hover {
  background: var(--sidebar-bg-hover);
  color: var(--sidebar-text);
}

.nav-link:hover i {
  color: var(--feu-gold);
}

.nav-item.active .nav-link {
  background: var(--feu-gold);
  color: var(--sidebar-bg);
  font-weight: 600;
}

.nav-item.active .nav-link i {
  color: var(--sidebar-bg);
}

/* == Topbar == */
.topbar {
  height: 64px;
  background: var(--bg-card);
  border-bottom: 1px solid var(--border-light);
  display: flex;
  align-items: center;
  padding: 0 24px;
  gap: 16px;
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}

.menu-btn {
  background: none;
  border: none;
  font-size: 18px;
  color: var(--text-secondary);
  cursor: pointer;
  padding: 6px;
  border-radius: var(--radius-sm);
  transition: background 0.2s, color 0.2s;
}

.menu-btn:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.topbar-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.topbar-right {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 16px;
  color: var(--text-secondary);
}

.topbar-right > i {
  font-size: 18px;
  cursor: pointer;
  padding: 6px;
  border-radius: var(--radius-sm);
  transition: background 0.2s, color 0.2s;
}

.topbar-right > i:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.user-chip {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-secondary);
  padding: 6px 12px;
  background: var(--bg-hover);
  border-radius: 20px;
}

.user-chip i {
  font-size: 18px;
  color: var(--accent-primary);
}

.logout-link {
  color: var(--text-secondary);
  text-decoration: none;
  font-weight: 500;
  padding: 6px 12px;
  border: 1px solid var(--border-light);
  border-radius: var(--radius-sm);
  transition: all 0.2s ease;
  font-size: 13px;
}

.logout-link:hover {
  background: #fef2f2;
  color: #dc2626;
  border-color: #fecaca;
}

/* == Page Content == */
.page-content {
  padding: 24px;
  flex: 1;
  background: var(--bg-primary);
}

/* == Alert Banners == */
.alert-banner {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  border-radius: var(--radius-md);
  font-size: 13px;
  font-weight: 500;
  margin-bottom: 20px;
}

.alert-success {
  background: #dcfce7;
  color: #166534;
  border: 1px solid #bbf7d0;
}

.alert-error {
  background: #fef2f2;
  color: #991b1b;
  border: 1px solid #fecaca;
}

/* == Stats Grid == */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}

.stat-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 14px;
  border: 1px solid var(--border-light);
  transition: box-shadow 0.2s;
}

.stat-card:hover {
  box-shadow: var(--shadow-md);
}

.stat-icon {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}

.icon-blue { background: #3b82f6; }
.icon-green { background: var(--accent-primary); }
.icon-gold { background: var(--accent-gold); }
.icon-red { background: #ef4444; }
.icon-purple { background: #8b5cf6; }

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 2px;
}

.stat-value {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
}

.stat-value-large {
  font-size: 26px;
  font-weight: 700;
  color: var(--text-primary);
}

.stat-card-center {
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 6px;
}

/* == Panels & Sections == */
.section-block {
  margin-bottom: 24px;
}

.section-title {
  margin: 0 0 14px;
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.section-title i {
  color: var(--accent-gold);
  margin-right: 8px;
}

.panel {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 20px;
  border: 1px solid var(--border-light);
}

.panel-table {
  padding: 0;
  overflow: hidden;
}

/* == Tables == */
.requests-table {
  width: 100%;
  border-collapse: collapse;
}

.requests-table th {
  text-align: left;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-muted);
  font-weight: 600;
  padding: 14px 12px;
  border-bottom: 1px solid var(--border-light);
}

.requests-table td {
  font-size: 14px;
  color: #334155;
  padding: 14px 12px;
  border-bottom: 1px solid #f8fafc;
  vertical-align: middle;
}

.requests-table tr:last-child td {
  border-bottom: none;
}

.requests-table tr:hover td {
  background: #f8fafc;
}

/* == Status Tags == */
.status-tag {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

.status-ready, .status-approved, .status-available {
  background: #dcfce7;
  color: #166534;
}

.status-pending {
  background: #fef3c7;
  color: #92400e;
}

.status-busy, .status-reserved {
  background: #dbeafe;
  color: #1e40af;
}

.status-cancelled, .status-rejected {
  background: #fee2e2;
  color: #991b1b;
}

.status-out-for-repair {
  background: #f3e8ff;
  color: #6b21a8;
}

.status-unavailable {
  background: #f1f5f9;
  color: #475569;
}

/* == Buttons == */
.request-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  background: var(--accent-primary);
  color: #ffffff;
  border: none;
  padding: 8px 14px;
  border-radius: var(--radius-md);
  font-size: 12px;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.2s, transform 0.1s, box-shadow 0.2s;
}

.request-btn:hover {
  background: var(--accent-primary-hover);
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(10, 92, 46, 0.3);
}

.request-btn-secondary {
  background: var(--text-secondary);
  color: #ffffff;
}

.request-btn-secondary:hover {
  background: #334155;
}

.reserve-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  background: var(--accent-primary);
  color: #ffffff;
  border: none;
  padding: 6px 12px;
  border-radius: var(--radius-sm);
  font-size: 12px;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.2s;
}

.reserve-btn:hover {
  background: var(--accent-primary-hover);
}

/* == Profile Grid == */
.profile-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.profile-label {
  display: block;
  color: var(--text-muted);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  margin-bottom: 2px;
}

.profile-value {
  display: block;
  color: var(--text-primary);
  font-weight: 600;
  font-size: 14px;
}

/* == Quick Actions == */
.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.quick-actions .request-btn {
  width: 100%;
}

/* == Dashboard Columns == */
.dashboard-columns {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 20px;
  margin-bottom: 24px;
  align-items: start;
}

.side-column {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* == Empty State == */
.empty-state {
  text-align: center;
  padding: 40px 20px;
}

.empty-state-title {
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4px;
  font-size: 15px;
}

.empty-state-desc {
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 16px;
}

/* == Responsive == */
@media (max-width: 900px) {
  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .dashboard-columns {
    grid-template-columns: 1fr;
  }

  .profile-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 600px) {
  body {
    flex-direction: column;
  }

  .main-sidebar {
    width: 100%;
    min-height: auto;
  }

  .main-sidebar.collapsed {
    transform: translateX(-100%);
    display: block;
  }

  .content-wrapper {
    margin-left: 0;
  }

  .stats-grid {
    grid-template-columns: 1fr;
  }

  .page-content {
    padding: 16px;
  }
}

/* Utility */
.move-up {
  margin-top: -10px;
}